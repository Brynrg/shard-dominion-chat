{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shard Dominion Building",
  "type": "object",
  "required": ["id", "name", "faction", "cost", "hp", "footprint", "powerGenerated", "powerUsed"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "faction": { "type": "string" },
    "cost": { "type": "integer", "minimum": 0 },
    "hp": { "type": "integer", "minimum": 1 },
    "footprint": { "type": "object", "properties": { "w": {"type":"integer"}, "h": {"type":"integer"} }, "required": ["w", "h"] },
    "powerGenerated": { "type": "integer" },
    "powerUsed": { "type": "integer" },
    "requiresLattice": { "type": "boolean" },
    "produces": { "type": "array", "items": { "type": "string" } },
    "abilities": { "type": "array", "items": { "type": "string" } }
  }
}
