{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shard Dominion Mission",
  "type": "object",
  "required": ["id", "title", "faction", "mapId", "briefing", "objectives"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "faction": { "type": "string" },
    "mapId": { "type": "string" },
    "briefing": { "type": "string" },
    "objectives": { "type": "array", "items": { "type": "object" } },
    "optionalObjectives": { "type": "array", "items": { "type": "object" } },
    "rewards": { "type": "array", "items": { "type": "string" } }
  }
}
