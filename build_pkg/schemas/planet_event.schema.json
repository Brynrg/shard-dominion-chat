{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shard Dominion Planet Event",
  "type": "object",
  "required": ["id", "name", "trigger", "effects"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "trigger": { "type": "object" },
    "warningSeconds": { "type": "number" },
    "effects": { "type": "array", "items": { "type": "object" } }
  }
}
